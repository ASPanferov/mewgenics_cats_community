# Vercel Postgres (from Vercel dashboard → Storage → Postgres)
POSTGRES_URL=postgres://user:pass@host:5432/dbname

# Vercel Blob (from Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Google OAuth (from console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Gemini API key
GEMINI_API_KEY=AIzaSy...

# JWT secret (generate random: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change_me_to_random_64_char_hex

# App URL (your Vercel deployment URL)
APP_URL=https://your-app.vercel.app
